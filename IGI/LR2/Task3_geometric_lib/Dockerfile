# 1. Берем образ Python с DockerHub
FROM python:3.10-slim

# 2. Создаем рабочую папку /app внутри контейнера
WORKDIR /app

# 3. Копируем все файлы из текущей папки Windows в папку /app контейнера
COPY . .

# 4. Устанавливаем переменные окружения по умолчанию (3a)
ENV RADIUS=5
ENV SIDE=10

# 5. Команда, кот. будет выполняться при старте контейнера
CMD ["python", "script.py"]