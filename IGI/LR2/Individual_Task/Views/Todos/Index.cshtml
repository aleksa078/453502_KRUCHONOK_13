@model IEnumerable<DotNetCoreSqlDb.Models.Todo>

@{
    ViewData["Title"] = "Мои задачи";
}

<div class="page-header-custom">
    <h2>Мои задачи 📝</h2>
    <div class="create-btn-wrapper">
        <a asp-action="Create" class="btn btn-custom-create">+ Создать новую</a>
    </div>
</div>

<div class="table-responsive bg-white rounded-table-wrapper">
    <table class="table table-hover modern-table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Description)</th>
                <th>@Html.DisplayNameFor(model => model.CreatedDate)</th>
                <th class="text-right">Действия</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td class="task-desc">
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td class="task-date">
                    @Html.DisplayFor(modelItem => item.CreatedDate)
                </td>
                <td class="text-right table-actions">
                    <a asp-action="Edit" asp-route-id="@item.ID" class="btn-action btn-edit">✏️ Изменить</a>
                    <a asp-action="Details" asp-route-id="@item.ID" class="btn-action btn-details">ℹ️ Детали</a>
                    <a asp-action="Delete" asp-route-id="@item.ID" class="btn-action btn-delete">❌ Удалить</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>